# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Template de configuration
#  INSTRUCTIONS :
#    1. Copier ce fichier : cp .env.example .env
#    2. Remplir toutes les valeurs marquées CHANGE_ME
#    3. Ne jamais committer le fichier .env  (voir .gitignore)
#
#  Générer des secrets forts :
#    python -c "import secrets; print(secrets.token_urlsafe(64))"
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=defectdojo
POSTGRES_USER=defectdojo
DD_DATABASE_URL=postgresql://defectdojo:defectdojo@db:5432/defectdojo
DD_SECRET_KEY=change-me-in-production-use-long-random-string
DD_CREDENTIAL_AES_256_KEY=change-me-16-char




