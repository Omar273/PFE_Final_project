# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Template de configuration
#  INSTRUCTIONS :
#    1. Copier ce fichier : cp .env.example .env
#    2. Remplir toutes les valeurs marquées CHANGE_ME
#    3. Ne jamais committer le fichier .env  (voir .gitignore)
#
#  Générer des secrets forts :
#    python -c "import secrets; print(secrets.token_urlsafe(64))"
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=defectdojo
POSTGRES_USER=defectdojo
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── DefectDojo ────────────────────────────────────────────────────────────────
# Django secret key — min 50 caractères aléatoires
DD_SECRET_KEY=CHANGE_ME_long_random_django_secret_key_min_50_chars
# Clé AES-256 pour le chiffrement des credentials — exactement 32 caractères
DD_CREDENTIAL_AES_256_KEY=CHANGE_ME_exactly_32_chars_aes!!
# Hosts autorisés (mettre votre domaine en prod, ex: mon-serveur.example.com)
DD_ALLOWED_HOSTS=localhost,127.0.0.1
# Admin par défaut (créé lors du premier démarrage)
DD_ADMIN_USER=admin
DD_ADMIN_PASSWORD=CHANGE_ME_admin_password
DD_ADMIN_MAIL=admin@example.com

# ── ML Backend ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Optionnel : token pour protéger l'API ML en production
ML_API_SECRET_TOKEN=CHANGE_ME_ml_api_token

# ── Redis ─────────────────────────────────────────────────────────────────────
# Laisser vide pour pas de mot de passe (réseau interne Docker seulement)
REDIS_PASSWORD=


