# ─────────────────────────────────────────────────────────────────────────────
#  .gitignore — Racine du projet pfe_project
# ─────────────────────────────────────────────────────────────────────────────

# !! SECRETS — ne jamais committer !!
.env
*.env
!.env.example          # le template est autorisé

# ── ML artifacts ──────────────────────────────────────────────────────────────
ml-backend/models/
ml-backend/data/
*.joblib
*.pkl
*.h5

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/

# ── Node / React ──────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Docker ────────────────────────────────────────────────────────────────────
docker-data/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
